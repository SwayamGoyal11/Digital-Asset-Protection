# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./antigravity.db

# ─── Auth ─────────────────────────────────────────────────────────────────────
SECRET_KEY=supersecretkey-change-in-production-32chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ─── IP Geolocation (free tier - no key needed) ───────────────────────────────
GEO_API_URL=http://ip-api.com/json

# ─── Risk Engine Thresholds ───────────────────────────────────────────────────
RISK_THRESHOLD_HIGH=70
RISK_THRESHOLD_MEDIUM=40

# ─── CORS ─────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ─── MongoDB (optional – leave blank to use TinyDB fallback) ──────────────────
MONGO_URI=
MONGO_DB_NAME=antigravity_logs
