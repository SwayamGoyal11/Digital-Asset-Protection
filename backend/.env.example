# Database
# Local development:
DATABASE_URL=sqlite:///./antigravity.db
# Production on Vercel should use hosted Postgres, for example:
# DATABASE_URL=postgresql+psycopg://<user>:<password>@<host>/<database>?sslmode=require

# Auth
SECRET_KEY=change-this-to-a-long-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# IP Geolocation
GEO_API_URL=http://ip-api.com/json

# Risk Engine Thresholds
RISK_THRESHOLD_HIGH=70
RISK_THRESHOLD_MEDIUM=40

# CORS
FRONTEND_URL=http://localhost:3000

# MongoDB Atlas mirror
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-url>/?appName=Cluster0
MONGO_DB_NAME=vaultx
